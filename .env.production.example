# PortfolioIQ — production environment (backend only).
# Copy to .env.production on the EC2 and fill in real values.
# chmod 600 .env.production
# Never commit .env.production to git.

# ─── Django ──────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=replace-with-50-char-random-string
DJANGO_DEBUG=false

# Add Vercel domain to CSRF — frontend will POST here
DJANGO_ALLOWED_HOSTS=api.portfolioiq.com,EC2_PUBLIC_IP,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://portfolioiq.com,https://www.portfolioiq.com,https://portfolioiq.vercel.app

# Trust X-Forwarded-Proto from Cloudflare/nginx
USE_X_FORWARDED_HOST=true
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https

# CORS — frontend on Vercel is a different origin
CORS_ALLOWED_ORIGINS=https://portfolioiq.com,https://www.portfolioiq.com,https://portfolioiq.vercel.app
# Allow Vercel preview deploys (each PR has a unique subdomain)
CORS_ALLOWED_ORIGIN_REGEX=^https://portfolioiq-[\w-]+\.vercel\.app$

# ─── Database ────────────────────────────────────────────────
POSTGRES_DB=portfolioiq
POSTGRES_USER=portfolioiq
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Elasticsearch ───────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# ─── External APIs ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Leave blank to use free yfinance fallback
POLYGON_API_KEY=
MARKET_DATA_PROVIDER=yfinance

TELEGRAM_BOT_TOKEN=123456:ABC...

# ─── Google OAuth (optional) ─────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Sentry (optional, error monitoring) ─────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ─── Backup config ───────────────────────────────────────────
S3_BACKUP_BUCKET=portfolioiq-backups