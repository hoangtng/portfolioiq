# PortfolioIQ — production environment.
# Copy to `.env.production` on the server and fill in real values.
# Never commit the actual .env.production file.

# ─── Django ──────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-50-char-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=portfolioiq.com,www.portfolioiq.com,EC2_PUBLIC_IP
DJANGO_CSRF_TRUSTED_ORIGINS=https://portfolioiq.com,https://www.portfolioiq.com

# Behind a reverse proxy/Cloudflare — trust X-Forwarded-Proto
USE_X_FORWARDED_HOST=true
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https

# ─── Database ────────────────────────────────────────────────
# All-in-one mode (Postgres in docker-compose):
POSTGRES_DB=portfolioiq
POSTGRES_USER=portfolioiq
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# AWS RDS mode — comment the line above and uncomment:
# POSTGRES_HOST=portfolioiq.xxx.us-east-1.rds.amazonaws.com

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ─── Redis ───────────────────────────────────────────────────
# All-in-one mode (Redis in docker-compose):
REDIS_URL=redis://redis:6379/0

# ElastiCache mode — comment the line above and uncomment:
# REDIS_URL=redis://portfolioiq.xxx.cache.amazonaws.com:6379/0

# Celery
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ─── External APIs ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
MASSIVE_API_KEY=replace-with-massive-key
TELEGRAM_BOT_TOKEN=123456:ABC...

# ─── Email (optional, for password resets) ──────────────────
EMAIL_HOST=smtp.resend.com
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_...
EMAIL_PORT=587
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@portfolioiq.com

# ─── Frontend (build-time, public) ──────────────────────────
# This is exposed to the browser — only put non-secret values here.
NEXT_PUBLIC_API_URL=https://portfolioiq.com

# ─── Sentry (optional error monitoring) ─────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ─── AWS (only if using S3 for media) ───────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=portfolioiq-media
# AWS_S3_REGION_NAME=us-east-1
