# ─── Django ───────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-generate-with-python-secrets-token-urlsafe-50
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
DJANGO_TIME_ZONE=UTC

# ─── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgres://portfolioiq:portfolioiq_dev@db:5432/portfolioiq

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=django-db

# ─── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# ─── CORS / Frontend ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Auth ─────────────────────────────────────────────────────
# Get Google client ID at https://console.cloud.google.com/
GOOGLE_OAUTH_CLIENT_ID=................
GOOGLE_OAUTH_CLIENT_SECRET=................

# ─── External APIs ───────────────────────────────────────────
# Massive (formerly Polygon.io) — free at https://massive.com/dashboard/signup
POLYGON_API_KEY=................

# Phase 2 — fill in when you reach those phases
ANTHROPIC_API_KEY=................
TELEGRAM_BOT_TOKEN=................
